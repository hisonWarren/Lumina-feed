  "engines": {
    "node": ">=22.18"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "keytar": "^7.9.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.7.76"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.24.2",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.35.2"
  },
  "build": {
    "appId": "com.hisonwarren.luminafeed",
    "productName": "Lumina Feed",
    "copyright": "© hisonWarren",
    "publish": [
      {
        "provider": "github",
        "owner": "hisonWarren",
        "repo": "Lumina-feed"
      }
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "files": [
      "build/**/*",
      "dist/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*",
      "**/node_modules/keytar/**/*"
    ],
    "fileAssociations": [
      {
        "ext": "pdf",
        "name": "PDF Document",
        "description": "PDF",
        "role": "Viewer",
        "rank": "Alternate"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "artifactName": "Lumina-Feed-${version}-windows-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.productivity",
      "artifactName": "Lumina-Feed-${version}-macos-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "AppImage",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Office",
      "mimeTypes": [
        "application/pdf"
      ],
      "artifactName": "Lumina-Feed-${version}-linux-${arch}.${ext}"
    }
  }
}
